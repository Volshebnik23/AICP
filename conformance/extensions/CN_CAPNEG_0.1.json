{
  "suite_id": "CN-CAPNEG-0.1",
  "suite_version": "0.1.0-dev",
  "aicp_version": "0.1",
  "description": "EXT-CAPNEG conformance checks for negotiation flow and payload schema.",
  "schema_ref": "schemas/core/aicp-core-message.schema.json",
  "payload_schema_ref": "schemas/extensions/ext-capneg-payloads.schema.json",
  "payload_schema_map": {
    "CAPABILITIES_DECLARE": "/$defs/CAPABILITIES_DECLARE",
    "CAPABILITIES_PROPOSE": "/$defs/CAPABILITIES_PROPOSE",
    "CAPABILITIES_ACCEPT": "/$defs/CAPABILITIES_ACCEPT",
    "CAPABILITIES_REJECT": "/$defs/CAPABILITIES_REJECT"
  },
  "transcripts": [
    {
      "id": "CN-01",
      "path": "fixtures/extensions/capneg/CN-01_basic_negotiation.jsonl",
      "expected_message_types": [
        "CAPABILITIES_DECLARE",
        "CAPABILITIES_PROPOSE",
        "CAPABILITIES_ACCEPT"
      ]
    },
    {
      "id": "CN-02",
      "path": "fixtures/extensions/capneg/CN-02_reject_incompatible_profile.jsonl",
      "expected_message_types": [
        "CAPABILITIES_DECLARE",
        "CAPABILITIES_PROPOSE",
        "CAPABILITIES_REJECT"
      ]
    },
    {
      "id": "CN-NEG-01",
      "path": "fixtures/extensions/capneg/CN-NEG-01_downgrade_attempt_expected_fail.jsonl",
      "expected_message_types": [
        "CAPABILITIES_DECLARE",
        "CAPABILITIES_PROPOSE",
        "CAPABILITIES_ACCEPT",
        "CAPABILITIES_PROPOSE"
      ],
      "expect_pass": false,
      "expected_failures": [
        {
          "test_id": "CN-DOWNGRADE-01",
          "min_count": 1
        }
      ]
    },
    {
      "id": "CN-05",
      "path": "fixtures/extensions/capneg/CN-05_profile_agree_mediated_blocking_pass.jsonl",
      "expected_message_types": [
        "CAPABILITIES_DECLARE",
        "CAPABILITIES_DECLARE",
        "CAPABILITIES_PROPOSE",
        "CAPABILITIES_ACCEPT"
      ]
    },
    {
      "id": "CN-06",
      "path": "fixtures/extensions/capneg/CN-06_profile_downgrade_attempt_expected_fail.jsonl",
      "expected_message_types": [
        "CAPABILITIES_DECLARE",
        "CAPABILITIES_DECLARE",
        "CAPABILITIES_PROPOSE",
        "CAPABILITIES_REJECT"
      ],
      "expect_pass": false,
      "expected_failures": [
        {
          "test_id": "CN-AICP-PROFILE-NEGOTIATION-01",
          "min_count": 1
        }
      ]
    }
  ],
  "checks": [
    {
      "test_id": "CT-SCHEMA-JSONL-01",
      "description": "Validate each JSONL record against Core message schema"
    },
    {
      "test_id": "CT-MESSAGE-TYPE-REGISTRY-01",
      "description": "message_type values must be registered in registry/message_types.json"
    },
    {
      "test_id": "CN-PAYLOAD-SCHEMA-01",
      "description": "Validate payload against EXT-CAPNEG payload schema"
    },
    {
      "test_id": "CT-HASH-CHAIN-01",
      "description": "prev_msg_hash equals previous message_hash when present"
    },
    {
      "test_id": "CT-INVARIANTS-01",
      "description": "session_id is constant and message_id values are unique per transcript"
    },
    {
      "test_id": "CT-SEQUENCE-01",
      "description": "message_type sequence matches expected per transcript"
    },
    {
      "test_id": "CT-MESSAGE-HASH-01",
      "description": "recompute message_hash from message body and compare"
    },
    {
      "test_id": "CN-DOWNGRADE-01",
      "description": "Detect unilateral downgrade/inconsistent negotiated required_extensions after acceptance without mutual renegotiation"
    },
    {
      "test_id": "CN-AICP-PROFILE-NEGOTIATION-01",
      "description": "selected.aicp_profile must be registered and acceptable/supported by declared participants"
    },
    {
      "test_id": "CN-REASON-CODES-01",
      "description": "CAPABILITIES_REJECT reason_code values must be registered CAPNEG reason codes"
    },
    {
      "test_id": "CN-PRIVACY-MODES-01",
      "description": "CAPNEG privacy_mode values must be registered or namespaced"
    }
  ],
  "compatibility_mark": "AICP-EXT-CAPNEG-0.1"
}
