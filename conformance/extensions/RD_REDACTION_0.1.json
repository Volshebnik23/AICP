  "checks": [
    {
      "test_id": "CT-SCHEMA-JSONL-01",
      "description": "Validate each JSONL record against Core message schema"
    },
    {
      "test_id": "CT-MESSAGE-TYPE-REGISTRY-01",
      "description": "message_type values must be registered in registry/message_types.json"
    },
    {
      "test_id": "CT-HASH-CHAIN-01",
      "description": "prev_msg_hash equals previous message_hash when present"
    },
    {
      "test_id": "CT-PREV-MSG-REQUIRED-01",
      "description": "For non-first transcript records, prev_msg_hash must be present and non-empty"
    },
    {
      "test_id": "CT-INVARIANTS-01",
      "description": "session_id is constant and message_id values are unique per transcript"
    },
    {
      "test_id": "CT-SEQUENCE-01",
      "description": "message_type sequence matches expected per transcript"
    },
    {
      "test_id": "CT-MESSAGE-HASH-01",
      "description": "recompute message_hash from message body and compare"
    },
    {
      "test_id": "RD-ORIGINAL-BIND-01",
      "description": "CONTENT_REDACTED.original_message_hash must reference an earlier transcript message_hash"
    },
    {
      "test_id": "RD-POLICY-REF-01",
      "description": "CONTENT_REDACTED.redaction_policy_ref must be present and non-empty"
    },
    {
      "test_id": "RD-PROOF-01",
      "description": "CONTENT_REDACTED.redaction_proof must be present and structurally valid"
    },
    {
      "test_id": "RD-PII-REF-01",
      "description": "pii_refs entries must match pii_ref schema and avoid inline plaintext PII fields"
    },
    {
      "test_id": "RD-RETENTION-CONTRACT-01",
      "description": "contract.ext.redaction.retention_policy must include required fields and valid values when declared"
    },
    {
      "test_id": "RD-CHAIN-INTEGRITY-01",
      "description": "redaction is a new declaration (hash-chain intact; redaction hash distinct from original_message_hash)"
    },
    {
      "test_id": "RD-POLICY-CATEGORY-01",
      "description": "contract.ext.redaction.retention_policy.policy_category must be the standardized retention/deletion category"
    },
    {
      "test_id": "RD-DELETE-SEMANTICS-01",
      "description": "retention_policy.delete_semantics must use standardized values"
    }
  ],
  "compatibility_mark": "AICP-EXT-REDACTION-0.1"
}
