    "STATE_SYNC_REQUEST": "#/$defs/STATE_SYNC_REQUEST",
    "STATE_SYNC_RESPONSE": "#/$defs/STATE_SYNC_RESPONSE"
  },
  "transcripts": [
    {
      "id": "OR-01",
      "path": "fixtures/extensions/object_resync/OR-01_object_request_response.jsonl",
