{
  "suite_id": "PR-PROVENANCE-0.1",
  "suite_version": "0.1.0-dev",
  "aicp_version": "0.1",
  "description": "EXT-PROVENANCE conformance for DAG linkage and append-only semantics.",
  "schema_ref": "schemas/core/aicp-core-message.schema.json",
  "payload_schema_ref": "schemas/extensions/ext-provenance-payloads.schema.json",
  "payload_schema_map": {
    "PROVENANCE_DECLARE": "#/$defs/PROVENANCE_DECLARE",
    "PROVENANCE_APPEND": "#/$defs/PROVENANCE_APPEND"
  },
  "transcripts": [
    {
      "id": "PR-01",
      "path": "fixtures/extensions/provenance/PR-01_dag_multi_agent_pass.jsonl",
      "expected_message_types": [
        "PROVENANCE_DECLARE",
        "PROVENANCE_APPEND",
        "PROVENANCE_APPEND"
      ]
    },
    {
      "id": "PR-02",
      "path": "fixtures/extensions/provenance/PR-02_append_missing_parent_expected_fail.jsonl",
      "expected_message_types": [
        "PROVENANCE_DECLARE",
        "PROVENANCE_APPEND"
      ],
      "expect_pass": false,
      "expected_failures": [
        {
          "test_id": "PR-LINK-01",
          "min_count": 1
        }
      ]
    },
    {
      "id": "PR-03",
      "path": "fixtures/extensions/provenance/PR-03_append_duplicate_node_expected_fail.jsonl",
      "expected_message_types": [
        "PROVENANCE_DECLARE",
        "PROVENANCE_APPEND"
      ],
      "expect_pass": false,
      "expected_failures": [
        {
          "test_id": "PR-APPEND-01",
          "min_count": 1
        }
      ]
    }
  ],
  "checks": [
    {
      "test_id": "CT-SCHEMA-JSONL-01",
      "description": "Validate each JSONL record against Core message schema"
    },
    {
      "test_id": "CT-MESSAGE-TYPE-REGISTRY-01",
      "description": "message_type values must be registered in registry/message_types.json"
    },
    {
      "test_id": "CN-PAYLOAD-SCHEMA-01",
      "description": "Validate payload against extension payload schema"
    },
    {
      "test_id": "CT-HASH-CHAIN-01",
      "description": "prev_msg_hash equals previous message_hash when present"
    },
    {
      "test_id": "CT-MESSAGE-HASH-01",
      "description": "recompute message_hash from message body and compare"
    },
    {
      "test_id": "CT-PREV-MSG-REQUIRED-01",
      "description": "For non-first transcript records, prev_msg_hash must be present and non-empty"
    },
    {
      "test_id": "CT-INVARIANTS-01",
      "description": "session_id constant and message_id unique"
    },
    {
      "test_id": "CT-SEQUENCE-01",
      "description": "message_type sequence matches expected per transcript"
    },
    {
      "test_id": "PR-NODE-01",
      "description": "provenance node types and required node fields are coherent"
    },
    {
      "test_id": "PR-LINK-01",
      "description": "parent linkage must reference known prior nodes in graph context"
    },
    {
      "test_id": "PR-APPEND-01",
      "description": "append operations are append-only and must target an existing graph"
    }
  ],
  "compatibility_mark": "AICP-EXT-PROVENANCE-0.1",
  "extension_id": "EXT-PROVENANCE"
}
