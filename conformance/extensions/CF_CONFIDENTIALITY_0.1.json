  "checks": [
    {
      "test_id": "CT-SCHEMA-JSONL-01",
      "description": "Validate each JSONL record against Core message schema"
    },
    {
      "test_id": "CT-MESSAGE-TYPE-REGISTRY-01",
      "description": "message_type values must be registered in registry/message_types.json"
    },
    {
      "test_id": "CT-HASH-CHAIN-01",
      "description": "prev_msg_hash equals previous message_hash when present"
    },
    {
      "test_id": "CT-PREV-MSG-REQUIRED-01",
      "description": "For non-first transcript records, prev_msg_hash must be present and non-empty"
    },
    {
      "test_id": "CT-INVARIANTS-01",
      "description": "session_id is constant and message_id values are unique per transcript"
    },
    {
      "test_id": "CT-SEQUENCE-01",
      "description": "message_type sequence matches expected per transcript"
    },
    {
      "test_id": "CT-MESSAGE-HASH-01",
      "description": "recompute message_hash from message body and compare"
    },
    {
      "test_id": "CF-CONTRACT-CONFIDENTIALITY-01",
      "description": "CONTRACT_PROPOSE.payload.contract.ext.confidentiality exists after CAPABILITIES_ACCEPT"
    },
    {
      "test_id": "CF-MODE-REGISTRY-01",
      "description": "confidentiality mode_id values must be registered privacy modes or namespaced"
    },
    {
      "test_id": "CF-CAPNEG-BIND-01",
      "description": "contract.ext.confidentiality.mode_id must match accepted CAPNEG selected.privacy_mode"
    },
    {
      "test_id": "CF-NEGRESULT-HASH-BIND-01",
      "description": "contract.ext.confidentiality.negotiation_result_hash must match accepted CAPNEG result hash"
    },
    {
      "test_id": "CF-REDACTION-ARTIFACTS-01",
      "description": "redacted mode requires non-empty redaction_artifact_refs"
    },
    {
      "test_id": "CF-METADATA-PROJECTION-01",
      "description": "metadata-only mode requires non-empty metadata_projection"
    },
    {
      "test_id": "CF-CLASSIFICATION-ARTIFACTS-01",
      "description": "classification-only mode requires non-empty classification_labels and classification_evidence_refs"
    }
  ],
  "compatibility_mark": "AICP-EXT-CONFIDENTIALITY-0.1"
