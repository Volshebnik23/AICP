{
  "suite_id": "ID-IDENTITY-LC-0.1",
  "suite_version": "0.1.0-dev",
  "aicp_version": "0.1",
  "description": "EXT-IDENTITY-LC conformance checks for announce/rotation/revoke invariants.",
  "schema_ref": "schemas/core/aicp-core-message.schema.json",
  "payload_schema_ref": "schemas/extensions/ext-identity-lc-payloads.schema.json",
  "payload_schema_map": {
    "IDENTITY_ANNOUNCE": "#/$defs/IDENTITY_ANNOUNCE",
    "KEY_ROTATION": "#/$defs/KEY_ROTATION",
    "KEY_REVOKE": "#/$defs/KEY_REVOKE",
    "AGENT_MIGRATION": "#/$defs/AGENT_MIGRATION"
  },
  "transcripts": [
    {
      "id": "IL-01",
      "path": "fixtures/extensions/identity_lc/IL-01_announce_and_verify_session_local_key.jsonl",
      "expected_message_types": [
        "CONTRACT_PROPOSE",
        "CONTRACT_ACCEPT",
        "IDENTITY_ANNOUNCE",
        "ATTEST_ACTION"
      ]
    },
    {
      "id": "IL-02",
      "path": "fixtures/extensions/identity_lc/IL-02_rotation_cross_sign_and_use_new_key.jsonl",
      "expected_message_types": [
        "CONTRACT_PROPOSE",
        "CONTRACT_ACCEPT",
        "IDENTITY_ANNOUNCE",
        "KEY_ROTATION",
        "ATTEST_ACTION"
      ]
    },
    {
      "id": "IL-03",
      "path": "fixtures/extensions/identity_lc/IL-03_revoke_then_use_revoked_key_expected_fail.jsonl",
      "expected_message_types": [
        "CONTRACT_PROPOSE",
        "CONTRACT_ACCEPT",
        "IDENTITY_ANNOUNCE",
        "KEY_ROTATION",
        "KEY_REVOKE",
        "CONTEXT_AMEND"
      ],
      "expect_pass": false,
      "expected_failures": [
        {
          "test_id": "ID-REVOKE-01",
          "min_count": 1
        }
      ]
    }
  ],
  "checks": [
    {"test_id": "CT-SCHEMA-JSONL-01", "description": "Validate each JSONL record against Core message schema"},
    {"test_id": "CT-MESSAGE-TYPE-REGISTRY-01", "description": "message_type values must be registered in registry/message_types.json"},
    {"test_id": "CN-PAYLOAD-SCHEMA-01", "description": "Validate payload against EXT-IDENTITY-LC payload schema"},
    {"test_id": "CT-HASH-CHAIN-01", "description": "prev_msg_hash equals previous message_hash when present"},
    {"test_id": "CT-INVARIANTS-01", "description": "session_id is constant and message_id values are unique per transcript"},
    {"test_id": "CT-SEQUENCE-01", "description": "message_type sequence matches expected per transcript"},
    {"test_id": "CT-MESSAGE-HASH-01", "description": "recompute message_hash from message body and compare"},
    {"test_id": "CT-SIGNATURE-HASH-01", "description": "if signatures[*].object_hash is present, it equals message_hash"},
    {"test_id": "CT-SIGNATURE-VERIFY-01", "description": "verify Ed25519 signatures using baseline + session-local identity lifecycle keyring"},
    {"test_id": "ID-AID-01", "description": "aid_ref.object_hash must match recomputed object_hash('aid', aid_ref.object)"},
    {"test_id": "ID-ANN-01", "description": "IDENTITY_ANNOUNCE aid_hash must match aid_ref.object_hash when aid_ref is present"},
    {"test_id": "ID-ROT-01", "description": "KEY_ROTATION cross-signature hashes and signatures must be valid"},
    {"test_id": "ID-REVOKE-01", "description": "revoked kid must not be used for subsequent contract-changing operations"}
  ],
  "compatibility_mark": "AICP-EXT-IDENTITY-LC-0.1"
}
