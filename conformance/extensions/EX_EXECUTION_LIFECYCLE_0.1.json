{
  "suite_id": "EX-EXECUTION-LIFECYCLE-0.1",
  "suite_version": "0.1.0-dev",
  "aicp_version": "0.1",
  "description": "EXT-EXECUTION-LIFECYCLE conformance for run/thread lifecycle ordering, terminal-state safety, and store-ref linkage.",
  "schema_ref": "schemas/core/aicp-core-message.schema.json",
  "payload_schema_ref": "schemas/extensions/ext-execution-lifecycle-payloads.schema.json",
  "payload_schema_map": {
    "RUN_CREATE": "#/$defs/RUN_CREATE",
    "RUN_UPDATE": "#/$defs/RUN_UPDATE",
    "RUN_CANCEL": "#/$defs/RUN_CANCEL",
    "RUN_COMPLETE": "#/$defs/RUN_COMPLETE",
    "THREAD_CREATE": "#/$defs/THREAD_CREATE",
    "THREAD_APPEND": "#/$defs/THREAD_APPEND",
    "THREAD_CLOSE": "#/$defs/THREAD_CLOSE"
  },
  "transcripts": [
    {
      "id": "EX-01",
      "path": "fixtures/extensions/execution_lifecycle/EX-01_basic_run_lifecycle_pass.jsonl",
      "expected_message_types": [
        "CONTRACT_PROPOSE",
        "CONTRACT_ACCEPT",
        "RUN_CREATE",
        "RUN_UPDATE",
        "RUN_COMPLETE"
      ]
    },
    {
      "id": "EX-02",
      "path": "fixtures/extensions/execution_lifecycle/EX-02_thread_lifecycle_pass.jsonl",
      "expected_message_types": [
        "CONTRACT_PROPOSE",
        "CONTRACT_ACCEPT",
        "THREAD_CREATE",
        "THREAD_APPEND",
        "THREAD_CLOSE"
      ]
    },
    {
      "id": "EX-03",
      "path": "fixtures/extensions/execution_lifecycle/EX-03_store_ref_resolved_pass.jsonl",
      "expected_message_types": [
        "RUN_CREATE",
        "OBJECT_REQUEST",
        "OBJECT_RESPONSE",
        "RUN_UPDATE"
      ]
    },
    {
      "id": "EX-04",
      "path": "fixtures/extensions/execution_lifecycle/EX-04_run_update_before_create_expected_fail.jsonl",
      "expected_message_types": [
        "RUN_UPDATE"
      ],
      "expect_pass": false,
      "expected_failures": [
        {
          "test_id": "EX-RUN-REF-01",
          "min_count": 1
        }
      ]
    },
    {
      "id": "EX-05",
      "path": "fixtures/extensions/execution_lifecycle/EX-05_post_terminal_mutation_expected_fail.jsonl",
      "expected_message_types": [
        "RUN_CREATE",
        "RUN_CANCEL",
        "RUN_UPDATE"
      ],
      "expect_pass": false,
      "expected_failures": [
        {
          "test_id": "EX-RUN-TERMINAL-01",
          "min_count": 1
        }
      ]
    },
    {
      "id": "EX-06",
      "path": "fixtures/extensions/execution_lifecycle/EX-06_thread_append_after_close_expected_fail.jsonl",
      "expected_message_types": [
        "THREAD_CREATE",
        "THREAD_CLOSE",
        "THREAD_APPEND"
      ],
      "expect_pass": false,
      "expected_failures": [
        {
          "test_id": "EX-THREAD-CLOSED-01",
          "min_count": 1
        }
      ]
    },
    {
      "id": "EX-07",
      "path": "fixtures/extensions/execution_lifecycle/EX-07_dangling_store_ref_expected_fail.jsonl",
      "expected_message_types": [
        "RUN_CREATE"
      ],
      "expect_pass": false,
      "expected_failures": [
        {
          "test_id": "EX-STORE-LINK-01",
          "min_count": 1
        }
      ]
    }
  ],
  "checks": [
    {"test_id": "CT-SCHEMA-JSONL-01", "description": "Validate each JSONL record against Core message schema"},
    {"test_id": "CT-MESSAGE-TYPE-REGISTRY-01", "description": "message_type values must be registered in registry/message_types.json"},
    {"test_id": "CN-PAYLOAD-SCHEMA-01", "description": "Validate payload against EXT-EXECUTION-LIFECYCLE payload schema"},
    {"test_id": "CT-HASH-CHAIN-01", "description": "prev_msg_hash equals previous message_hash when present"},
    {"test_id": "CT-PREV-MSG-REQUIRED-01", "description": "For non-first transcript records, prev_msg_hash must be present and non-empty"},
    {"test_id": "CT-INVARIANTS-01", "description": "session_id constant and message_id unique"},
    {"test_id": "CT-SEQUENCE-01", "description": "message_type sequence matches expected per transcript"},
    {"test_id": "CT-MESSAGE-HASH-01", "description": "recompute message_hash from message body and compare"},
    {"test_id": "EX-RUN-REF-01", "description": "run mutation messages must reference a previously created run_id"},
    {"test_id": "EX-RUN-TRANSITION-01", "description": "invalid run state transitions must fail"},
    {"test_id": "EX-RUN-TERMINAL-01", "description": "run mutations are forbidden after terminal state"},
    {"test_id": "EX-THREAD-REF-01", "description": "THREAD_APPEND and THREAD_CLOSE require prior THREAD_CREATE"},
    {"test_id": "EX-THREAD-CLOSED-01", "description": "closed threads must reject append/close mutations"},
    {"test_id": "EX-STORE-REF-01", "description": "store_ref/memory_ref require hash-bound object and access constraints"},
    {"test_id": "EX-STORE-LINK-01", "description": "resolution-required store/memory refs must have OBJECT_RESPONSE evidence"},
    {"test_id": "EX-CROSS-BIND-01", "description": "run_id/thread_id cross-binding must remain coherent when declared"}
  ],
  "compatibility_mark": "AICP-EXT-EXECUTION-LIFECYCLE-0.1",
  "extension_id": "EXT-EXECUTION-LIFECYCLE"
}
