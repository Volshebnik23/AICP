{
  "suite_id": "RC-RECEPTION-CHAT-SEMANTICS-0.1",
  "suite_version": "0.1.0-dev",
  "aicp_version": "0.1",
  "description": "Cross-extension reception chat semantics checks for contract configuration and mediator-only delivery under blocking enforcement.",
  "schema_ref": "schemas/core/aicp-core-message.schema.json",
  "transcripts": [
    {
