{
  "suite_id": "CH-CHANNELS-0.1",
  "suite_version": "0.1.0-dev",
  "aicp_version": "0.1",
  "description": "EXT-CHANNELS conformance for hierarchy and lifecycle semantics.",
  "schema_ref": "schemas/core/aicp-core-message.schema.json",
  "payload_schema_ref": "schemas/extensions/ext-channels-payloads.schema.json",
  "payload_schema_map": {
    "CHANNEL_DECLARE": "#/$defs/CHANNEL_DECLARE",
    "CHANNEL_UPDATE": "#/$defs/CHANNEL_UPDATE",
    "CHANNEL_DEPRECATE": "#/$defs/CHANNEL_DEPRECATE"
  },
  "transcripts": [
    {
      "id": "CH-01",
      "path": "fixtures/extensions/channels/CH-01_channel_lifecycle_pass.jsonl",
      "expected_message_types": [
        "CHANNEL_DECLARE",
        "CHANNEL_DECLARE",
        "CHANNEL_UPDATE",
        "CHANNEL_DEPRECATE"
      ]
    },
    {
      "id": "CH-02",
      "path": "fixtures/extensions/channels/CH-02_missing_parent_expected_fail.jsonl",
      "expected_message_types": [
        "CHANNEL_DECLARE"
      ],
      "expect_pass": false,
      "expected_failures": [
        {
          "test_id": "CH-HIER-01",
          "min_count": 1
        }
      ]
    },
    {
      "id": "CH-03",
      "path": "fixtures/extensions/channels/CH-03_visibility_escalation_expected_fail.jsonl",
      "expected_message_types": [
        "CHANNEL_DECLARE",
        "CHANNEL_DECLARE"
      ],
      "expect_pass": false,
      "expected_failures": [
        {
          "test_id": "CH-HIER-01",
          "min_count": 1
        }
      ]
    }
  ],
  "checks": [
    {"test_id": "CT-SCHEMA-JSONL-01", "description": "Validate each JSONL record against Core message schema"},
    {"test_id": "CT-MESSAGE-TYPE-REGISTRY-01", "description": "message_type values must be registered in registry/message_types.json"},
    {"test_id": "CN-PAYLOAD-SCHEMA-01", "description": "Validate payload against extension payload schema"},
    {"test_id": "CT-HASH-CHAIN-01", "description": "prev_msg_hash equals previous message_hash when present"},
    {"test_id": "CT-MESSAGE-HASH-01", "description": "recompute message_hash from message body and compare"},
    {"test_id": "CT-PREV-MSG-REQUIRED-01", "description": "For non-first transcript records, prev_msg_hash must be present and non-empty"},
    {"test_id": "CT-INVARIANTS-01", "description": "session_id constant and message_id unique"},
    {"test_id": "CT-SEQUENCE-01", "description": "message_type sequence matches expected per transcript"},
    {"test_id": "CH-HIER-01", "description": "channel parent linkage and visibility hierarchy must be coherent"},
    {"test_id": "CH-LIFECYCLE-01", "description": "channel updates/deprecations must target declared channels"}
  ],
  "compatibility_mark": "AICP-EXT-CHANNELS-0.1",
  "extension_id": "EXT-CHANNELS"
}
