{
  "suite_id": "RP-RESPONSIBILITY-0.1",
  "suite_version": "0.1.0-dev",
  "aicp_version": "0.1",
  "description": "EXT-RESPONSIBILITY conformance for transfer lifecycle and chain-failure attestation.",
  "schema_ref": "schemas/core/aicp-core-message.schema.json",
  "payload_schema_ref": "schemas/extensions/ext-responsibility-payloads.schema.json",
  "payload_schema_map": {
    "RESPONSIBILITY_ASSIGN": "#/$defs/RESPONSIBILITY_ASSIGN",
    "RESPONSIBILITY_ACCEPT": "#/$defs/RESPONSIBILITY_ACCEPT",
    "RESPONSIBILITY_REVOKE": "#/$defs/RESPONSIBILITY_REVOKE",
    "CHAIN_FAILURE_ATTEST": "#/$defs/CHAIN_FAILURE_ATTEST"
  },
  "transcripts": [
    {
      "id": "RP-01",
      "path": "fixtures/extensions/responsibility/RP-01_assign_accept_failure_attest_pass.jsonl",
      "expected_message_types": [
        "PROVENANCE_DECLARE",
        "RESPONSIBILITY_ASSIGN",
        "RESPONSIBILITY_ACCEPT",
        "CHAIN_FAILURE_ATTEST",
        "OBS_SIGNAL"
      ]
    },
    {
      "id": "RP-02",
      "path": "fixtures/extensions/responsibility/RP-02_accept_without_assign_expected_fail.jsonl",
      "expected_message_types": [
        "RESPONSIBILITY_ACCEPT"
      ],
      "expect_pass": false,
      "expected_failures": [
        {
          "test_id": "RS-ACCEPT-01",
          "min_count": 1
        }
      ]
    },
    {
      "id": "RP-03",
      "path": "fixtures/extensions/responsibility/RP-03_missing_terminal_transfer_expected_fail.jsonl",
      "expected_message_types": [
        "RESPONSIBILITY_ASSIGN"
      ],
      "expect_pass": false,
      "expected_failures": [
        {
          "test_id": "RS-LIFECYCLE-01",
          "min_count": 1
        }
      ]
    },
    {
      "id": "RP-04",
      "path": "fixtures/extensions/responsibility/RP-04_transient_failure_without_retry_expected_fail.jsonl",
      "expected_message_types": [
        "RESPONSIBILITY_ASSIGN",
        "RESPONSIBILITY_ACCEPT",
        "CHAIN_FAILURE_ATTEST"
      ],
      "expect_pass": false,
      "expected_failures": [
        {
          "test_id": "RS-CHAIN-01",
          "min_count": 1
        }
      ]
    },
    {
      "id": "RP-05",
      "path": "fixtures/extensions/responsibility/RP-05_failure_with_missing_provenance_expected_fail.jsonl",
      "expected_message_types": [
        "RESPONSIBILITY_ASSIGN",
        "RESPONSIBILITY_ACCEPT",
        "CHAIN_FAILURE_ATTEST"
      ],
      "expect_pass": false,
      "expected_failures": [
        {
          "test_id": "RS-CHAIN-01",
          "min_count": 1
        }
      ]
    }
  ],
  "checks": [
    {
      "test_id": "CT-SCHEMA-JSONL-01",
      "description": "Validate each JSONL record against Core message schema"
    },
    {
      "test_id": "CT-MESSAGE-TYPE-REGISTRY-01",
      "description": "message_type values must be registered in registry/message_types.json"
    },
    {
      "test_id": "CN-PAYLOAD-SCHEMA-01",
      "description": "Validate payload against extension payload schema"
    },
    {
      "test_id": "CT-HASH-CHAIN-01",
      "description": "prev_msg_hash equals previous message_hash when present"
    },
    {
      "test_id": "CT-MESSAGE-HASH-01",
      "description": "recompute message_hash from message body and compare"
    },
    {
      "test_id": "CT-PREV-MSG-REQUIRED-01",
      "description": "For non-first transcript records, prev_msg_hash must be present and non-empty"
    },
    {
      "test_id": "CT-INVARIANTS-01",
      "description": "session_id constant and message_id unique"
    },
    {
      "test_id": "CT-SEQUENCE-01",
      "description": "message_type sequence matches expected per transcript"
    },
    {
      "test_id": "RS-ASSIGN-01",
      "description": "responsibility assignments must carry machine-checkable context"
    },
    {
      "test_id": "RS-ACCEPT-01",
      "description": "accept/revoke must reference known prior assignments with valid reason codes"
    },
    {
      "test_id": "RS-LIFECYCLE-01",
      "description": "each assignment must conclude via explicit accept or revoke"
    },
    {
      "test_id": "RS-CHAIN-01",
      "description": "chain failure attestation must carry coherent classification/retry/rollback evidence"
    }
  ],
  "compatibility_mark": "AICP-EXT-RESPONSIBILITY-0.1",
  "extension_id": "EXT-RESPONSIBILITY"
}
