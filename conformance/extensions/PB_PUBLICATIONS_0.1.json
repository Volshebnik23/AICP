{
  "suite_id": "PB-PUBLICATIONS-0.1",
  "suite_version": "0.1.0-dev",
  "aicp_version": "0.1",
  "description": "EXT-PUBLICATIONS conformance for publish/update/retract and delivery-policy semantics.",
  "schema_ref": "schemas/core/aicp-core-message.schema.json",
  "payload_schema_ref": "schemas/extensions/ext-publications-payloads.schema.json",
  "payload_schema_map": {
    "PUBLICATION_PUBLISH": "#/$defs/PUBLICATION_PUBLISH",
    "PUBLICATION_UPDATE": "#/$defs/PUBLICATION_UPDATE",
    "PUBLICATION_RETRACT": "#/$defs/PUBLICATION_RETRACT"
  },
  "transcripts": [
    {
      "id": "PB-01",
      "path": "fixtures/extensions/publications/PB-01_publish_update_retract_with_policy_pass.jsonl",
      "expected_message_types": [
        "CONTRACT_PROPOSE",
        "SUBSCRIBE",
        "PUBLICATION_PUBLISH",
        "PUBLICATION_UPDATE",
        "PUBLICATION_RETRACT",
        "OBS_SIGNAL"
      ]
    },
    {
      "id": "PB-02",
      "path": "fixtures/extensions/publications/PB-02_update_without_publish_expected_fail.jsonl",
      "expected_message_types": [
        "PUBLICATION_UPDATE"
      ],
      "expect_pass": false,
      "expected_failures": [
        {"test_id": "PB-LIFECYCLE-01", "min_count": 1}
      ]
    },
    {
      "id": "PB-03",
      "path": "fixtures/extensions/publications/PB-03_update_without_version_progression_expected_fail.jsonl",
      "expected_message_types": [
        "PUBLICATION_PUBLISH",
        "PUBLICATION_UPDATE"
      ],
      "expect_pass": false,
      "expected_failures": [
        {"test_id": "PB-LIFECYCLE-01", "min_count": 1}
      ]
    },
    {
      "id": "PB-04",
      "path": "fixtures/extensions/publications/PB-04_retract_with_unknown_reason_expected_fail.jsonl",
      "expected_message_types": [
        "PUBLICATION_PUBLISH",
        "PUBLICATION_RETRACT"
      ],
      "expect_pass": false,
      "expected_failures": [
        {"test_id": "PB-REASON-01", "min_count": 1}
      ]
    },
    {
      "id": "PB-05",
      "path": "fixtures/extensions/publications/PB-05_must_reach_without_delivery_proof_expected_fail.jsonl",
      "expected_message_types": [
        "CONTRACT_PROPOSE",
        "PUBLICATION_PUBLISH"
      ],
      "expect_pass": false,
      "expected_failures": [
        {"test_id": "PB-DELIVERY-01", "min_count": 1}
      ]
    }
  ],
  "checks": [
    {"test_id": "CT-SCHEMA-JSONL-01", "description": "Validate each JSONL record against Core message schema"},
    {"test_id": "CT-MESSAGE-TYPE-REGISTRY-01", "description": "message_type values must be registered in registry/message_types.json"},
    {"test_id": "CN-PAYLOAD-SCHEMA-01", "description": "Validate payload against extension payload schema"},
    {"test_id": "CT-HASH-CHAIN-01", "description": "prev_msg_hash equals previous message_hash when present"},
    {"test_id": "CT-MESSAGE-HASH-01", "description": "recompute message_hash from message body and compare"},
    {"test_id": "CT-PREV-MSG-REQUIRED-01", "description": "For non-first transcript records, prev_msg_hash must be present and non-empty"},
    {"test_id": "CT-INVARIANTS-01", "description": "session_id constant and message_id unique"},
    {"test_id": "CT-SEQUENCE-01", "description": "message_type sequence matches expected per transcript"},
    {"test_id": "PB-LIFECYCLE-01", "description": "publication update/retract must link to an existing publication version chain"},
    {"test_id": "PB-REASON-01", "description": "publication retract reason_code must be valid and machine-readable"},
    {"test_id": "PB-DELIVERY-01", "description": "must-reach publication policy requires delivery proof references"}
  ],
  "compatibility_mark": "AICP-EXT-PUBLICATIONS-0.1",
  "extension_id": "EXT-PUBLICATIONS"
}
