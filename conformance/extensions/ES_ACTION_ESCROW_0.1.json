{
  "suite_id": "ES-ACTION-ESCROW-0.1",
  "suite_version": "0.1.0-dev",
  "aicp_version": "0.1",
  "description": "EXT-ACTION-ESCROW conformance for two-phase action safety and hash binding.",
  "schema_ref": "schemas/core/aicp-core-message.schema.json",
  "payload_schema_ref": "schemas/extensions/ext-action-escrow-payloads.schema.json",
  "payload_schema_map": {
    "ACTION_PREPARE": "#/$defs/ACTION_PREPARE",
    "ACTION_APPROVE": "#/$defs/ACTION_APPROVE",
    "ACTION_COMMIT": "#/$defs/ACTION_COMMIT"
  },
  "transcripts": [
    {
      "id": "ES-01",
      "path": "fixtures/extensions/action_escrow/ES-01_prepare_approve_commit_pass.jsonl",
      "expected_message_types": [
        "ACTION_PREPARE",
        "ACTION_APPROVE",
        "ACTION_COMMIT"
      ]
    },
    {
      "id": "ES-02",
      "path": "fixtures/extensions/action_escrow/ES-02_commit_without_prepare_expected_fail.jsonl",
      "expected_message_types": [
        "ACTION_COMMIT"
      ],
      "expect_pass": false,
      "expected_failures": [
        {
          "test_id": "ES-FLOW-01",
          "min_count": 1
        }
      ]
    },
    {
      "id": "ES-03",
      "path": "fixtures/extensions/action_escrow/ES-03_commit_without_approve_expected_fail.jsonl",
      "expected_message_types": [
        "ACTION_PREPARE",
        "ACTION_COMMIT"
      ],
      "expect_pass": false,
      "expected_failures": [
        {
          "test_id": "ES-FLOW-01",
          "min_count": 1
        }
      ]
    },
    {
      "id": "ES-04",
      "path": "fixtures/extensions/action_escrow/ES-04_commit_binding_mismatch_expected_fail.jsonl",
      "expected_message_types": [
        "ACTION_PREPARE",
        "ACTION_APPROVE",
        "ACTION_COMMIT"
      ],
      "expect_pass": false,
      "expected_failures": [
        {
          "test_id": "ES-BIND-01",
          "min_count": 1
        }
      ]
    }
  ],
  "checks": [
    {
      "test_id": "CT-SCHEMA-JSONL-01",
      "description": "Validate each JSONL record against Core message schema"
    },
    {
      "test_id": "CT-MESSAGE-TYPE-REGISTRY-01",
      "description": "message_type values must be registered in registry/message_types.json"
    },
    {
      "test_id": "CN-PAYLOAD-SCHEMA-01",
      "description": "Validate payload against extension payload schema"
    },
    {
      "test_id": "CT-HASH-CHAIN-01",
      "description": "prev_msg_hash equals previous message_hash when present"
    },
    {
      "test_id": "CT-MESSAGE-HASH-01",
      "description": "recompute message_hash from message body and compare"
    },
    {
      "test_id": "CT-PREV-MSG-REQUIRED-01",
      "description": "For non-first transcript records, prev_msg_hash must be present and non-empty"
    },
    {
      "test_id": "CT-INVARIANTS-01",
      "description": "session_id constant and message_id unique"
    },
    {
      "test_id": "CT-SEQUENCE-01",
      "description": "message_type sequence matches expected per transcript"
    },
    {
      "test_id": "ES-FLOW-01",
      "description": "commit must follow prepare and approve for escrow_id"
    },
    {
      "test_id": "ES-BIND-01",
      "description": "commit hashes must match prepare/approve bindings"
    }
  ],
  "compatibility_mark": "AICP-EXT-ACTION-ESCROW-0.1",
  "extension_id": "EXT-ACTION-ESCROW"
}
