{
  "suite_id": "TG-TOOL-GATING-0.1",
  "suite_version": "0.1.0-dev",
  "aicp_version": "0.1",
  "description": "EXT-TOOL-GATING conformance checks for blocking and audit modes.",
  "schema_ref": "schemas/core/aicp-core-message.schema.json",
  "payload_schema_ref": "schemas/extensions/ext-tool-gating-payloads.schema.json",
  "payload_schema_map": {
    "TOOL_CALL_REQUEST": "#/$defs/TOOL_CALL_REQUEST",
    "TOOL_CALL_VERDICT": "#/$defs/TOOL_CALL_VERDICT",
    "TOOL_CALL_RESULT": "#/$defs/TOOL_CALL_RESULT",
    "TOOL_CALL_ATTEST": "#/$defs/TOOL_CALL_ATTEST"
  },
  "transcripts": [
    {
      "id": "TG-01",
      "path": "fixtures/extensions/tool_gating/TG-01_blocking_allow.jsonl",
      "expected_message_types": [
        "CONTRACT_PROPOSE",
        "CONTRACT_ACCEPT",
        "TOOL_CALL_REQUEST",
        "TOOL_CALL_VERDICT",
        "TOOL_CALL_RESULT"
      ]
    },
    {
      "id": "TG-02",
      "path": "fixtures/extensions/tool_gating/TG-02_audit_result_attest.jsonl",
      "expected_message_types": [
        "CONTRACT_PROPOSE",
        "CONTRACT_ACCEPT",
        "TOOL_CALL_REQUEST",
        "TOOL_CALL_RESULT",
        "TOOL_CALL_ATTEST"
      ]
    },
    {
      "id": "TG-03",
      "path": "fixtures/extensions/tool_gating/TG-03_blocking_result_without_allow_expected_fail.jsonl",
      "expected_message_types": [
        "CONTRACT_PROPOSE",
        "CONTRACT_ACCEPT",
        "TOOL_CALL_REQUEST",
        "TOOL_CALL_RESULT"
      ],
      "expect_pass": false,
      "expected_failures": [
        {
          "test_id": "TG-MODE-01",
          "min_count": 1
        }
      ]
    },
    {
      "id": "TG-04",
      "path": "fixtures/extensions/tool_gating/TG-04_audit_missing_attest_expected_fail.jsonl",
      "expected_message_types": [
        "CONTRACT_PROPOSE",
        "CONTRACT_ACCEPT",
        "TOOL_CALL_REQUEST",
        "TOOL_CALL_RESULT"
      ],
      "expect_pass": false,
      "expected_failures": [
        {
          "test_id": "TG-MODE-01",
          "min_count": 1
        }
      ]
    }
  ],
  "checks": [
    {
      "test_id": "CT-SCHEMA-JSONL-01",
      "description": "Validate each JSONL record against Core message schema"
    },
    {
      "test_id": "CT-MESSAGE-TYPE-REGISTRY-01",
      "description": "message_type values must be registered in registry/message_types.json"
    },
    {
      "test_id": "CN-PAYLOAD-SCHEMA-01",
      "description": "Validate payload against EXT-TOOL-GATING payload schema"
    },
    {
      "test_id": "CT-HASH-CHAIN-01",
      "description": "prev_msg_hash equals previous message_hash when present"
    },
    {
      "test_id": "CT-PREV-MSG-REQUIRED-01",
      "description": "For non-first transcript records, prev_msg_hash must be present and non-empty"
    },
    {
      "test_id": "CT-INVARIANTS-01",
      "description": "session_id is constant and message_id values are unique per transcript"
    },
    {
      "test_id": "CT-SEQUENCE-01",
      "description": "message_type sequence matches expected per transcript"
    },
    {
      "test_id": "CT-MESSAGE-HASH-01",
      "description": "recompute message_hash from message body and compare"
    },
    {
      "test_id": "TG-REQ-01",
      "description": "TOOL_CALL_REQUEST must include non-empty tool_id and operation"
    },
    {
      "test_id": "TG-BIND-01",
      "description": "TOOL_CALL_VERDICT/RESULT/ATTEST target_request_hash must bind to an earlier TOOL_CALL_REQUEST"
    },
    {
      "test_id": "TG-AUTH-01",
      "description": "If acceptors are configured, only allowlisted senders may emit TOOL_CALL_VERDICT/TOOL_CALL_ATTEST"
    },
    {
      "test_id": "TG-MODE-01",
      "description": "Enforce blocking mode pre-ALLOW and audit mode post-attestation rules"
    }
  ],
  "compatibility_mark": "AICP-EXT-TOOL-GATING-0.1"
}
