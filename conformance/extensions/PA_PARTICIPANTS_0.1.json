{
  "suite_id": "PA-PARTICIPANTS-0.1",
  "suite_version": "0.1.0-dev",
  "aicp_version": "0.1",
  "description": "EXT-PARTICIPANTS conformance checks for join/accept membership gating and model rules.",
  "schema_ref": "schemas/core/aicp-core-message.schema.json",
  "payload_schema_ref": "schemas/extensions/ext-participants-payloads.schema.json",
  "payload_schema_map": {
    "PARTICIPANT_JOIN": "#/$defs/PARTICIPANT_JOIN",
    "PARTICIPANT_ACCEPT": "#/$defs/PARTICIPANT_ACCEPT",
    "PARTICIPANT_LEAVE": "#/$defs/PARTICIPANT_LEAVE"
  },
  "transcripts": [
    {
      "id": "PA-01",
      "path": "fixtures/extensions/participants/PA-01_shared_contract_join_accept.jsonl",
      "expected_message_types": [
        "CONTRACT_PROPOSE",
        "CONTRACT_ACCEPT",
        "PARTICIPANT_JOIN",
        "PARTICIPANT_ACCEPT",
        "ATTEST_ACTION"
      ]
    },
    {
      "id": "PA-02",
      "path": "fixtures/extensions/participants/PA-02_per_participant_acceptance_join_accept.jsonl",
      "expected_message_types": [
        "CONTRACT_PROPOSE",
        "CONTRACT_ACCEPT",
        "PARTICIPANT_JOIN",
        "PARTICIPANT_ACCEPT",
        "ATTEST_ACTION"
      ]
    },
    {
      "id": "PA-03",
      "path": "fixtures/extensions/participants/PA-03_message_before_accept_expected_fail.jsonl",
      "expected_message_types": [
        "CONTRACT_PROPOSE",
        "CONTRACT_ACCEPT",
        "PARTICIPANT_JOIN",
        "ATTEST_ACTION",
        "PARTICIPANT_ACCEPT"
      ],
      "expect_pass": false,
      "expected_failures": [
        {
          "test_id": "PA-MEM-01",
          "min_count": 1
        }
      ]
    }
  ],
  "checks": [
    {
      "test_id": "CT-SCHEMA-JSONL-01",
      "description": "Validate each JSONL record against Core message schema"
    },
    {
      "test_id": "CT-MESSAGE-TYPE-REGISTRY-01",
      "description": "message_type values must be registered in registry/message_types.json"
    },
    {
      "test_id": "CN-PAYLOAD-SCHEMA-01",
      "description": "Validate payload against EXT-PARTICIPANTS payload schema"
    },
    {
      "test_id": "CT-HASH-CHAIN-01",
      "description": "prev_msg_hash equals previous message_hash when present"
    },
    {
      "test_id": "CT-PREV-MSG-REQUIRED-01",
      "description": "For non-first transcript records, prev_msg_hash must be present and non-empty"
    },
    {
      "test_id": "CT-INVARIANTS-01",
      "description": "session_id is constant and message_id values are unique per transcript"
    },
    {
      "test_id": "CT-SEQUENCE-01",
      "description": "message_type sequence matches expected per transcript"
    },
    {
      "test_id": "CT-MESSAGE-HASH-01",
      "description": "recompute message_hash from message body and compare"
    },
    {
      "test_id": "PA-JOIN-01",
      "description": "PARTICIPANT_JOIN participant_id must be valid and equal sender"
    },
    {
      "test_id": "PA-ACCEPT-01",
      "description": "PARTICIPANT_ACCEPT must reference a participant that previously joined"
    },
    {
      "test_id": "PA-MEM-01",
      "description": "Participants cannot send gated messages before acceptance or after leave"
    },
    {
      "test_id": "PA-AUTH-01",
      "description": "If acceptors are configured, PARTICIPANT_ACCEPT sender must be allowed"
    },
    {
      "test_id": "PA-MODEL-01",
      "description": "Model-specific rules for shared_contract and per_participant_acceptance"
    }
  ],
  "compatibility_mark": "AICP-EXT-PARTICIPANTS-0.1"
}
