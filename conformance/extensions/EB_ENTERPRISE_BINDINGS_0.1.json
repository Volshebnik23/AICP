{
  "suite_id": "EB-ENTERPRISE-BINDINGS-0.1",
  "suite_version": "0.1.0-dev",
  "aicp_version": "0.1",
  "description": "EXT-ENTERPRISE-BINDINGS conformance checks for OpenAPI/OData bindings and ABAC-RBAC-OPA policy cross-references.",
  "schema_ref": "schemas/core/aicp-core-message.schema.json",
  "payload_schema_ref": "schemas/extensions/ext-enterprise-bindings-payloads.schema.json",
  "payload_schema_map": {
    "CONTRACT_PROPOSE": "#/$defs/CONTRACT_PROPOSE",
    "TOOL_CALL_REQUEST": "#/$defs/TOOL_CALL_REQUEST"
  },
  "transcripts": [
    {
      "id": "EB-01",
      "path": "fixtures/extensions/enterprise_bindings/EB-01_openapi_tool_binding_pass.jsonl",
      "expected_message_types": ["CONTRACT_PROPOSE", "CONTRACT_ACCEPT", "TOOL_CALL_REQUEST"]
    },
    {
      "id": "EB-02",
      "path": "fixtures/extensions/enterprise_bindings/EB-02_odata_retrieval_binding_pass.jsonl",
      "expected_message_types": ["CONTRACT_PROPOSE", "CONTRACT_ACCEPT", "TOOL_CALL_REQUEST"]
    },
    {
      "id": "EB-03",
      "path": "fixtures/extensions/enterprise_bindings/EB-03_policy_xref_binding_pass.jsonl",
      "expected_message_types": ["CONTRACT_PROPOSE", "CONTRACT_ACCEPT", "TOOL_CALL_REQUEST"]
    },
    {
      "id": "EB-04",
      "path": "fixtures/extensions/enterprise_bindings/EB-04_enterprise_flow_with_iam_and_approval_pass.jsonl",
      "expected_message_types": ["CONTRACT_PROPOSE", "CONTRACT_ACCEPT", "APPROVAL_CHALLENGE", "APPROVAL_GRANT", "TOOL_CALL_REQUEST", "OBS_SIGNAL"]
    },
    {
      "id": "EB-05",
      "path": "fixtures/extensions/enterprise_bindings/EB-05_missing_openapi_operation_ref_expected_fail.jsonl",
      "expected_message_types": ["CONTRACT_PROPOSE", "CONTRACT_ACCEPT", "TOOL_CALL_REQUEST"],
      "expect_pass": false,
      "expected_failures": [{"test_id": "EB-OPENAPI-BIND-01", "min_count": 1}]
    },
    {
      "id": "EB-06",
      "path": "fixtures/extensions/enterprise_bindings/EB-06_invalid_odata_target_expected_fail.jsonl",
      "expected_message_types": ["CONTRACT_PROPOSE", "CONTRACT_ACCEPT", "TOOL_CALL_REQUEST"],
      "expect_pass": false,
      "expected_failures": [{"test_id": "EB-ODATA-BIND-01", "min_count": 1}]
    },
    {
      "id": "EB-07",
      "path": "fixtures/extensions/enterprise_bindings/EB-07_invalid_policy_kind_expected_fail.jsonl",
      "expected_message_types": ["CONTRACT_PROPOSE", "CONTRACT_ACCEPT", "TOOL_CALL_REQUEST"],
      "expect_pass": false,
      "expected_failures": [{"test_id": "EB-POLICY-KIND-01", "min_count": 1}]
    },
    {
      "id": "EB-08",
      "path": "fixtures/extensions/enterprise_bindings/EB-08_binding_without_required_correlation_expected_fail.jsonl",
      "expected_message_types": ["CONTRACT_PROPOSE", "CONTRACT_ACCEPT", "TOOL_CALL_REQUEST", "OBS_SIGNAL"],
      "expect_pass": false,
      "expected_failures": [{"test_id": "EB-OBS-CORRELATION-01", "min_count": 1}]
    }
  ],
  "checks": [
    {"test_id": "CT-SCHEMA-JSONL-01", "description": "Validate each JSONL record against Core message schema"},
    {"test_id": "CT-MESSAGE-TYPE-REGISTRY-01", "description": "message_type values must be registered in registry/message_types.json"},
    {"test_id": "CN-PAYLOAD-SCHEMA-01", "description": "Validate payload against EXT-ENTERPRISE-BINDINGS payload schema"},
    {"test_id": "CT-HASH-CHAIN-01", "description": "prev_msg_hash equals previous message_hash when present"},
    {"test_id": "CT-PREV-MSG-REQUIRED-01", "description": "For non-first transcript records, prev_msg_hash must be present and non-empty"},
    {"test_id": "CT-INVARIANTS-01", "description": "session_id is constant and message_id values are unique per transcript"},
    {"test_id": "CT-SEQUENCE-01", "description": "message_type sequence matches expected per transcript"},
    {"test_id": "CT-MESSAGE-HASH-01", "description": "recompute message_hash from message body and compare"},
    {"test_id": "EB-OPENAPI-BIND-01", "description": "openapi binding must include operation-level linkage for enterprise tool mapping"},
    {"test_id": "EB-ODATA-BIND-01", "description": "odata retrieval binding must include normalized target references and tool linkage consistency"},
    {"test_id": "EB-POLICY-XREF-01", "description": "policy cross-reference entries must include stable identifiers and references"},
    {"test_id": "EB-POLICY-KIND-01", "description": "policy_kind must be supported by EXT-ENTERPRISE-BINDINGS (abac/rbac/opa)"},
    {"test_id": "EB-IAM-LINK-01", "description": "enterprise-bound tool activity with iam_bridge action must map to declared policy_xref.action_ref"},
    {"test_id": "EB-APPROVAL-LINK-01", "description": "required enterprise-bound human approval tool calls must have prior APPROVAL_GRANT evidence"},
    {"test_id": "EB-OBS-CORRELATION-01", "description": "when requires_obs_correlation=true, enterprise-bound tool calls must correlate with OBS_SIGNAL evidence"},
    {"test_id": "EB-REFERENCE-INTEGRITY-01", "description": "TOOL_CALL_REQUEST enterprise binding refs must resolve to declared contract enterprise binding IDs"}
  ],
  "compatibility_mark": "AICP-EXT-ENTERPRISE-BINDINGS-0.1",
  "extension_id": "EXT-ENTERPRISE-BINDINGS"
}
