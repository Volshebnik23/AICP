    {
      "id": "EB-08",
      "path": "fixtures/extensions/enterprise_bindings/EB-08_binding_without_required_correlation_expected_fail.jsonl",
      "expected_message_types": ["CONTRACT_PROPOSE", "CONTRACT_ACCEPT", "TOOL_CALL_REQUEST", "OBS_SIGNAL"],
      "expect_pass": false,
      "expected_failures": [{"test_id": "EB-OBS-CORRELATION-01", "min_count": 1}]
    }
  ],
  "checks": [
    {"test_id": "CT-SCHEMA-JSONL-01", "description": "Validate each JSONL record against Core message schema"},
    {"test_id": "CT-MESSAGE-TYPE-REGISTRY-01", "description": "message_type values must be registered in registry/message_types.json"},
    {"test_id": "CN-PAYLOAD-SCHEMA-01", "description": "Validate payload shape for enterprise-binding contract and tool-call payloads"},
    {"test_id": "CT-HASH-CHAIN-01", "description": "prev_msg_hash equals previous message_hash when present"},
    {"test_id": "CT-PREV-MSG-REQUIRED-01", "description": "For non-first transcript records, prev_msg_hash must be present and non-empty"},
    {"test_id": "CT-INVARIANTS-01", "description": "session_id is constant and message_id values are unique per transcript"},
    {"test_id": "CT-SEQUENCE-01", "description": "message_type sequence matches expected per transcript"},
    {"test_id": "CT-MESSAGE-HASH-01", "description": "recompute message_hash from message body and compare"},
    {"test_id": "EB-OPENAPI-BIND-01", "description": "valid OpenAPI tool binding exists and maps to normalized operation reference"},
    {"test_id": "EB-ODATA-BIND-01", "description": "valid OData retrieval binding exists with normalized target linkage"},
    {"test_id": "EB-POLICY-XREF-01", "description": "policy cross-reference entries include valid xref_id and policy_ref shape"},
    {"test_id": "EB-POLICY-KIND-01", "description": "policy_kind must be one of abac/rbac/opa"},
    {"test_id": "EB-IAM-LINK-01", "description": "enterprise-bound IAM action references must link to policy action_ref evidence"},
    {"test_id": "EB-APPROVAL-LINK-01", "description": "required human approval enterprise calls must include prior matching grant evidence"},
    {"test_id": "EB-OBS-CORRELATION-01", "description": "when contract requires observability correlation, enterprise-bound calls must have matching OBS_SIGNAL tool_call correlation"},
    {"test_id": "EB-REFERENCE-INTEGRITY-01", "description": "tool-call enterprise binding references must resolve to declared contract binding ids"}
  ],
  "compatibility_mark": "AICP-EXT-ENTERPRISE-BINDINGS-0.1",
  "extension_id": "EXT-ENTERPRISE-BINDINGS"
}
