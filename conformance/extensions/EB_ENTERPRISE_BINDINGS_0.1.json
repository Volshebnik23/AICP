    {"id": "EB-05", "path": "fixtures/extensions/enterprise_bindings/EB-05_missing_openapi_operation_ref_expected_fail.jsonl", "expected_message_types": ["CONTRACT_PROPOSE", "CONTRACT_ACCEPT", "TOOL_CALL_REQUEST"], "expect_pass": false, "expected_failures": [{"test_id": "EB-OPENAPI-BIND-01", "min_count": 1}]},
    {"id": "EB-06", "path": "fixtures/extensions/enterprise_bindings/EB-06_invalid_odata_target_expected_fail.jsonl", "expected_message_types": ["CONTRACT_PROPOSE", "CONTRACT_ACCEPT", "TOOL_CALL_REQUEST"], "expect_pass": false, "expected_failures": [{"test_id": "EB-ODATA-BIND-01", "min_count": 1}]},
    {"id": "EB-07", "path": "fixtures/extensions/enterprise_bindings/EB-07_invalid_policy_kind_expected_fail.jsonl", "expected_message_types": ["CONTRACT_PROPOSE", "CONTRACT_ACCEPT", "POLICY_EVAL_REQUEST"], "expect_pass": false, "expected_failures": [{"test_id": "EB-POLICY-KIND-01", "min_count": 1}]},
    {"id": "EB-08", "path": "fixtures/extensions/enterprise_bindings/EB-08_binding_without_required_correlation_expected_fail.jsonl", "expected_message_types": ["CONTRACT_PROPOSE", "CONTRACT_ACCEPT", "TOOL_CALL_REQUEST"], "expect_pass": false, "expected_failures": [{"test_id": "EB-OBS-CORRELATION-01", "min_count": 1}]}
