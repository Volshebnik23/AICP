  "checks": [
    {"test_id": "CT-SCHEMA-JSONL-01", "description": "Validate each JSONL record against Core message schema"},
    {"test_id": "CT-MESSAGE-TYPE-REGISTRY-01", "description": "message_type values must be registered in registry/message_types.json"},
    {"test_id": "CT-HASH-CHAIN-01", "description": "prev_msg_hash equals previous message_hash when present"},
    {"test_id": "CT-INVARIANTS-01", "description": "session_id is constant and message_id values are unique per transcript"},
    {"test_id": "CT-SEQUENCE-01", "description": "message_type sequence matches expected per transcript"},
    {"test_id": "CT-MESSAGE-HASH-01", "description": "recompute message_hash from message body and compare"},
    {"test_id": "IB-ISSUER-01", "description": "issuer in normalized claims snapshot must satisfy contract allowlist"},
    {"test_id": "IB-SCOPE-MAP-01", "description": "required external scope mappings must be satisfied for protected action/delegation use"},
    {"test_id": "IB-ROLE-MAP-01", "description": "required role mappings must be satisfied for protected action/delegation use"},
    {"test_id": "IB-GROUP-MAP-01", "description": "required group mappings must be satisfied for protected action/delegation use"},
    {"test_id": "IB-BINDING-LINK-01", "description": "acting message must be traceable to valid delegated-identity subject binding context"},
    {"test_id": "IB-STEPUP-ACR-01", "description": "protected action requiring specific acr must fail when not satisfied"},
    {"test_id": "IB-STEPUP-AMR-01", "description": "protected action requiring amr method(s) must fail when not satisfied"},
    {"test_id": "IB-APPROVAL-MAP-01", "description": "actions requiring mapped approval must include required M26 approval evidence"}
  ],
  "compatibility_mark": "AICP-EXT-IAM-BRIDGE-0.1"
