{
  "suite_id": "WF-WORKFLOW-SYNC-0.1",
  "suite_version": "0.1.0-dev",
  "aicp_version": "0.1",
  "description": "EXT-WORKFLOW-SYNC conformance checks for declaration/update/step attest binding and monotonic step progress.",
  "schema_ref": "schemas/core/aicp-core-message.schema.json",
  "payload_schema_ref": "schemas/extensions/ext-workflow-sync-payloads.schema.json",
  "payload_schema_map": {
    "WORKFLOW_DECLARE": "#/$defs/WORKFLOW_DECLARE",
    "WORKFLOW_UPDATE": "#/$defs/WORKFLOW_UPDATE",
    "WORKFLOW_STEP_ATTEST": "#/$defs/WORKFLOW_STEP_ATTEST"
  },
  "transcripts": [
    {"id":"WF-01","path":"fixtures/extensions/workflow_sync/WF-01_declare_and_step_attest_pass.jsonl","expected_message_types":["CONTRACT_PROPOSE","CONTRACT_ACCEPT","WORKFLOW_DECLARE","WORKFLOW_STEP_ATTEST"]},
    {"id":"WF-02","path":"fixtures/extensions/workflow_sync/WF-02_update_and_monotonic_steps_pass.jsonl","expected_message_types":["CONTRACT_PROPOSE","CONTRACT_ACCEPT","WORKFLOW_DECLARE","WORKFLOW_UPDATE","WORKFLOW_STEP_ATTEST","WORKFLOW_STEP_ATTEST"]},
    {"id":"WF-03","path":"fixtures/extensions/workflow_sync/WF-03_step_without_declare_expected_fail.jsonl","expected_message_types":["CONTRACT_PROPOSE","CONTRACT_ACCEPT","WORKFLOW_STEP_ATTEST"],"expect_pass":false,"expected_failures":[{"test_id":"WF-REF-01","min_count":1}]},
    {"id":"WF-04","path":"fixtures/extensions/workflow_sync/WF-04_non_monotonic_step_index_expected_fail.jsonl","expected_message_types":["CONTRACT_PROPOSE","CONTRACT_ACCEPT","WORKFLOW_DECLARE","WORKFLOW_STEP_ATTEST","WORKFLOW_STEP_ATTEST"],"expect_pass":false,"expected_failures":[{"test_id":"WF-MONO-01","min_count":1}]}
  ],
  "checks": [
    {"test_id":"CT-SCHEMA-JSONL-01","description":"Validate each JSONL record against Core message schema"},
    {"test_id":"CT-MESSAGE-TYPE-REGISTRY-01","description":"message_type values must be registered in registry/message_types.json"},
    {"test_id":"CN-PAYLOAD-SCHEMA-01","description":"Validate payload against EXT-WORKFLOW-SYNC payload schema"},
    {"test_id":"CT-HASH-CHAIN-01","description":"prev_msg_hash equals previous message_hash when present"},
    {"test_id":"CT-INVARIANTS-01","description":"session_id is constant and message_id values are unique per transcript"},
    {"test_id":"CT-SEQUENCE-01","description":"message_type sequence matches expected per transcript"},
    {"test_id":"CT-MESSAGE-HASH-01","description":"recompute message_hash from message body and compare"},
    {"test_id":"WF-DECL-01","description":"WORKFLOW_DECLARE hash/head bindings must be valid"},
    {"test_id":"WF-UPD-01","description":"WORKFLOW_UPDATE must reference prior workflow hash and increase version"},
    {"test_id":"WF-REF-01","description":"WORKFLOW_STEP_ATTEST must reference a declared workflow_id"},
    {"test_id":"WF-MONO-01","description":"step_index for a workflow_id must be non-decreasing"},
    {"test_id":"WF-BIND-01","description":"WORKFLOW_STEP_ATTEST head/version/output bindings must be valid"}
  ],
  "compatibility_mark": "AICP-EXT-WORKFLOW-SYNC-0.1"
}
