{
  "suite_id": "RS-RESUME-0.1",
  "suite_version": "0.1.0-dev",
  "aicp_version": "0.1",
  "description": "EXT-RESUME conformance checks for session resume handshake matching and action registry validation.",
  "schema_ref": "schemas/core/aicp-core-message.schema.json",
  "payload_schema_ref": "schemas/extensions/ext-resume-payloads.schema.json",
  "payload_schema_map": {
    "RESUME_REQUEST": "#/$defs/RESUME_REQUEST",
    "RESUME_RESPONSE": "#/$defs/RESUME_RESPONSE"
  },
  "transcripts": [
    {
      "id": "RS-01",
      "path": "fixtures/extensions/resume/RS-01_ok_in_sync.jsonl",
      "expected_message_types": [
        "CONTRACT_PROPOSE",
        "CONTRACT_ACCEPT",
        "ATTEST_ACTION",
        "RESUME_REQUEST",
        "RESUME_RESPONSE"
      ]
    },
    {
      "id": "RS-02",
      "path": "fixtures/extensions/resume/RS-02_needs_resync.jsonl",
      "expected_message_types": [
        "CONTRACT_PROPOSE",
        "CONTRACT_ACCEPT",
        "ATTEST_ACTION",
        "ATTEST_ACTION",
        "RESUME_REQUEST",
        "RESUME_RESPONSE"
      ]
    },
    {
      "id": "RS-03",
      "path": "fixtures/extensions/resume/RS-03_missing_response_expected_fail.jsonl",
      "expected_message_types": [
        "CONTRACT_PROPOSE",
        "CONTRACT_ACCEPT",
        "ATTEST_ACTION",
        "RESUME_REQUEST"
      ],
      "expect_pass": false,
      "expected_failures": [
        {
          "test_id": "RS-RESUME-MATCH-01",
          "min_count": 1
        }
      ]
    },
    {
      "id": "RS-NEG-01",
      "path": "fixtures/extensions/resume/RS-NEG-01_forced_resync_loop_expected_fail.jsonl",
      "expected_message_types": [
        "CONTRACT_PROPOSE",
        "CONTRACT_ACCEPT",
        "ATTEST_ACTION",
        "RESUME_REQUEST",
        "RESUME_RESPONSE",
        "RESUME_REQUEST",
        "RESUME_RESPONSE",
        "RESUME_REQUEST",
        "RESUME_RESPONSE"
      ],
      "expect_pass": false,
      "expected_failures": [
        {
          "test_id": "RS-LOOP-01",
          "min_count": 1
        }
      ]
    }
  ],
  "checks": [
    {
      "test_id": "CT-SCHEMA-JSONL-01",
      "description": "Validate each JSONL record against Core message schema"
    },
    {
      "test_id": "CT-MESSAGE-TYPE-REGISTRY-01",
      "description": "message_type values must be registered in registry/message_types.json"
    },
    {
      "test_id": "CN-PAYLOAD-SCHEMA-01",
      "description": "Validate payload against EXT-RESUME payload schema"
    },
    {
      "test_id": "CT-HASH-CHAIN-01",
      "description": "prev_msg_hash equals previous message_hash when present"
    },
    {
      "test_id": "CT-INVARIANTS-01",
      "description": "session_id is constant and message_id values are unique per transcript"
    },
    {
      "test_id": "CT-MESSAGE-HASH-01",
      "description": "recompute message_hash from message body and compare"
    },
    {
      "test_id": "RS-RESUME-MATCH-01",
      "description": "RESUME_REQUEST must have matching RESUME_RESPONSE and status/hash relationship consistency"
    },
    {
      "test_id": "RS-ACTIONS-01",
      "description": "RESUME_RESPONSE recommended_actions values must be registered EXT-ALERTS action IDs"
    },
    {
      "test_id": "RS-LOOP-01",
      "description": "Detect repeated NEEDS_RESYNC resume cycles without head progress (suspicious forced loop)"
    }
  ],
  "compatibility_mark": "AICP-EXT-RESUME-0.1"
}
