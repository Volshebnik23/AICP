{
  "suite_id": "IB-INBOX-0.1",
  "suite_version": "0.1.0-dev",
  "aicp_version": "0.1",
  "description": "EXT-INBOX conformance for routing and lease/ack linkage semantics.",
  "schema_ref": "schemas/core/aicp-core-message.schema.json",
  "payload_schema_ref": "schemas/extensions/ext-inbox-payloads.schema.json",
  "payload_schema_map": {
    "INBOX_ENQUEUE": "#/$defs/INBOX_ENQUEUE",
    "INBOX_ROUTE": "#/$defs/INBOX_ROUTE",
    "INBOX_LEASE_GRANT": "#/$defs/INBOX_LEASE_GRANT",
    "INBOX_ACK": "#/$defs/INBOX_ACK"
  },
  "transcripts": [
    {
      "id": "IB-01",
      "path": "fixtures/extensions/inbox/IB-01_inbox_with_queue_lease_pass.jsonl",
      "expected_message_types": [
        "RESPONSIBILITY_ASSIGN",
        "INBOX_ENQUEUE",
        "INBOX_ROUTE",
        "INBOX_LEASE_GRANT",
        "INBOX_ACK",
        "OBS_SIGNAL"
      ]
    },
    {
      "id": "IB-02",
      "path": "fixtures/extensions/inbox/IB-02_ack_without_enqueue_expected_fail.jsonl",
      "expected_message_types": [
        "INBOX_ACK"
      ],
      "expect_pass": false,
      "expected_failures": [
        {"test_id": "IB-LINK-01", "min_count": 1}
      ]
    },
    {
      "id": "IB-03",
      "path": "fixtures/extensions/inbox/IB-03_missing_queue_lease_context_expected_fail.jsonl",
      "expected_message_types": [
        "CONTRACT_PROPOSE",
        "INBOX_ENQUEUE",
        "INBOX_ROUTE",
        "INBOX_LEASE_GRANT"
      ],
      "expect_pass": false,
      "expected_failures": [
        {"test_id": "IB-LEASE-01", "min_count": 1}
      ]
    }
  ],
  "checks": [
    {"test_id": "CT-SCHEMA-JSONL-01", "description": "Validate each JSONL record against Core message schema"},
    {"test_id": "CT-MESSAGE-TYPE-REGISTRY-01", "description": "message_type values must be registered in registry/message_types.json"},
    {"test_id": "CN-PAYLOAD-SCHEMA-01", "description": "Validate payload against extension payload schema"},
    {"test_id": "CT-HASH-CHAIN-01", "description": "prev_msg_hash equals previous message_hash when present"},
    {"test_id": "CT-MESSAGE-HASH-01", "description": "recompute message_hash from message body and compare"},
    {"test_id": "CT-PREV-MSG-REQUIRED-01", "description": "For non-first transcript records, prev_msg_hash must be present and non-empty"},
    {"test_id": "CT-INVARIANTS-01", "description": "session_id constant and message_id unique"},
    {"test_id": "CT-SEQUENCE-01", "description": "message_type sequence matches expected per transcript"},
    {"test_id": "IB-LINK-01", "description": "inbox route/ack must link to prior enqueue and lease context"},
    {"test_id": "IB-LEASE-01", "description": "lease grants must include queue/admission context when policy requires it"}
  ],
  "compatibility_mark": "AICP-EXT-INBOX-0.1",
  "extension_id": "EXT-INBOX"
}
