{
  "suite_id": "CT-CORE-0.1",
  "suite_version": "0.1.0-dev",
  "aicp_version": "0.1",
  "description": "Core v0.1 transcript checks over canonical golden fixtures.",
  "schema_ref": "schemas/core/aicp-core-message.schema.json",
  "transcripts": [
    {
      "id": "GT-01",
      "path": "fixtures/golden_transcripts/GT-01_happy_path_signed.jsonl",
      "expected_message_types": [
        "CONTRACT_PROPOSE",
        "CONTRACT_ACCEPT",
        "ATTEST_ACTION"
      ]
    },
    {
      "id": "GT-02",
      "path": "fixtures/golden_transcripts/GT-02_conflict_choose_signed.jsonl",
      "expected_message_types": [
        "CONTRACT_PROPOSE",
        "CONTRACT_ACCEPT",
        "CONTEXT_AMEND",
        "CONTEXT_AMEND",
        "RESOLVE_CONFLICT"
      ]
    },
    {
      "id": "GT-04",
      "path": "fixtures/golden_transcripts/GT-04_consent_required_and_grant.jsonl",
      "expected_message_types": [
        "CONTRACT_PROPOSE",
        "CONTRACT_ACCEPT",
        "CONTEXT_AMEND",
        "ATTEST_ACTION"
      ]
    },
    {
      "id": "GT-05",
      "path": "fixtures/golden_transcripts/GT-05_consent_revoke.jsonl",
      "expected_message_types": [
        "CONTRACT_PROPOSE",
        "CONTRACT_ACCEPT",
        "CONTEXT_AMEND",
        "CONTEXT_AMEND",
        "ATTEST_ACTION"
      ]
    },
    {
      "id": "GT-06",
      "path": "fixtures/golden_transcripts/GT-06_unknown_base_and_resync.jsonl",
      "expected_message_types": [
        "CONTRACT_PROPOSE",
        "CONTRACT_ACCEPT",
        "STATE_SYNC_REQUEST",
        "STATE_SYNC_RESPONSE",
        "CONTEXT_AMEND"
      ]
    },
    {
      "id": "GT-07",
      "path": "fixtures/golden_transcripts/GT-07_invalid_signature_reject.jsonl",
      "expected_message_types": [
        "CONTRACT_PROPOSE"
      ],
      "expect_pass": false,
      "expected_failures": [
        {
          "test_id": "CT-SIGNATURE-VERIFY-01",
          "min_count": 1
        }
      ]
    },
    {
      "id": "GT-08",
      "path": "fixtures/golden_transcripts/GT-08_replay_duplicate_message_id.jsonl",
      "expected_message_types": [
        "CONTRACT_PROPOSE",
        "CONTRACT_ACCEPT",
        "CONTRACT_ACCEPT"
      ],
      "expect_pass": false,
      "expected_failures": [
        {
          "test_id": "CT-INVARIANTS-01",
          "min_count": 1
        }
      ]
    }
  ],
  "checks": [
    {
      "test_id": "CT-SCHEMA-JSONL-01",
      "description": "Validate each JSONL record against Core message schema"
    },
    {
      "test_id": "CT-MESSAGE-TYPE-REGISTRY-01",
      "description": "message_type values must be registered in registry/message_types.json"
    },
    {
      "test_id": "CT-PAYLOAD-SCHEMA-01",
      "description": "Validate mapped Core payloads against core payload schema"
    },
    {
      "test_id": "CT-HASH-CHAIN-01",
      "description": "prev_msg_hash equals previous message_hash when present"
    },
    {
      "test_id": "CT-INVARIANTS-01",
      "description": "session_id is constant and message_id values are unique per transcript"
    },
    {
      "test_id": "CT-SEQUENCE-01",
      "description": "message_type sequence matches expected per transcript"
    },
    {
      "test_id": "CT-SIGNATURE-HASH-01",
      "description": "if signatures[*].object_hash is present, it equals message_hash"
    },
    {
      "test_id": "CT-MESSAGE-HASH-01",
      "description": "recompute message_hash from message body (excluding signatures/message_hash) and compare"
    },
    {
      "test_id": "CT-SIGNATURE-VERIFY-01",
      "description": "verify Ed25519 signatures using fixtures/keys/GT_public_keys.json"
    },
    {
      "test_id": "CT-CONTRACT-SCHEMA-01",
      "description": "CONTRACT_PROPOSE payload.contract must validate against core contract schema and match envelope contract_id"
    },
    {
      "test_id": "CT-POLICY-CATEGORIES-01",
      "description": "contract.policies categories must be registered or namespaced; policy_id values must be unique"
    }
  ],
  "payload_schema_ref": "schemas/core/aicp-core-payloads.schema.json",
  "payload_schema_map": {
    "CONTRACT_PROPOSE": "#/$defs/CONTRACT_PROPOSE",
    "CONTRACT_ACCEPT": "#/$defs/CONTRACT_ACCEPT",
    "CONTEXT_AMEND": "#/$defs/CONTEXT_AMEND",
    "ATTEST_ACTION": "#/$defs/ATTEST_ACTION",
    "RESOLVE_CONFLICT": "#/$defs/RESOLVE_CONFLICT"
  },
  "payload_schema_check_id": "CT-PAYLOAD-SCHEMA-01",
  "compatibility_mark": "AICP-Core-0.1"
}
