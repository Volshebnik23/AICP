{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aicp.dev/schemas/aicp-core-contract.schema.json",
  "title": "AICP Core Contract",
  "type": "object",
  "required": [
    "contract_id",
    "goal",
    "roles"
  ],
  "properties": {
    "contract_id": {
      "type": "string",
      "minLength": 1
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "roles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "policies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "policy_id",
          "category",
          "parameters"
        ],
        "properties": {
          "policy_id": {
            "type": "string",
            "minLength": 1
          },
          "category": {
            "type": "string",
            "minLength": 1
          },
          "parameters": {
            "type": "object",
            "default": {}
          },
          "version": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "active",
              "deprecated",
              "disabled"
            ]
          },
          "uri": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "extensions": {
      "type": "object"
    },
    "ext": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
