{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aicp.dev/schemas/aicp-core-payloads.schema.json",
  "title": "AICP Core Payload Schemas",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "CONTRACT_PROPOSE": {
      "type": "object",
      "required": [
        "contract"
      ],
      "properties": {
        "contract": {
          "type": "object",
          "additionalProperties": true
        },
        "contract_hash": {
          "type": "string",
          "minLength": 1
        },
        "note": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "CONTRACT_ACCEPT": {
      "type": "object",
      "required": [
        "accepted"
      ],
      "properties": {
        "accepted": {
          "type": "boolean"
        },
        "replay": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "CONTEXT_AMEND": {
      "type": "object",
      "required": [
        "amendment"
      ],
      "properties": {
        "amendment": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "ATTEST_ACTION": {
      "type": "object",
      "required": [
        "action_id",
        "action_type"
      ],
      "properties": {
        "action_id": {
          "type": "string",
          "minLength": 1
        },
        "action_type": {
          "type": "string",
          "minLength": 1
        },
        "result_hash": {
          "type": "string",
          "minLength": 1
        },
        "authority_ref": {
          "type": "string",
          "minLength": 1
        },
        "consent_ref": {
          "type": "string",
          "minLength": 1
        },
        "scope_ref": {
          "type": "string",
          "minLength": 1
        },
        "tool_name": {
          "type": "string",
          "minLength": 1
        }
      },
      "oneOf": [
        {
          "required": [
            "result_hash"
          ]
        },
        {
          "required": [
            "consent_ref"
          ]
        }
      ],
      "additionalProperties": false
    },
    "RESOLVE_CONFLICT": {
      "type": "object",
      "required": [
        "conflict_id",
        "conflict_class",
        "resolution",
        "candidates"
      ],
      "properties": {
        "conflict_id": {
          "type": "string",
          "minLength": 1
        },
        "conflict_class": {
          "type": "string",
          "minLength": 1
        },
        "resolution": {
          "type": "object",
          "additionalProperties": true
        },
        "candidates": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": false
    },
    "ERROR": {
      "type": "object",
      "required": [
        "error_code",
        "error_class",
        "severity",
        "applies_to",
        "disposition"
      ],
      "properties": {
        "error_code": {
          "type": "string",
          "minLength": 1
        },
        "error_class": {
          "type": "string",
          "enum": [
            "VALIDATION",
            "CRYPTO",
            "STATE",
            "POLICY",
            "RATE",
            "INTERNAL"
          ]
        },
        "severity": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "applies_to": {
          "type": "object",
          "properties": {
            "message_id": {
              "type": "string",
              "minLength": 1
            },
            "object_hash": {
              "type": "string",
              "minLength": 1
            }
          },
          "anyOf": [
            {
              "required": [
                "message_id"
              ]
            },
            {
              "required": [
                "object_hash"
              ]
            }
          ],
          "additionalProperties": false
        },
        "disposition": {
          "type": "string",
          "enum": [
            "IGNORED",
            "BUFFERED",
            "REJECTED"
          ]
        },
        "recover_action": {
          "type": "string",
          "enum": [
            "RETRY_LATER",
            "RESEND_MESSAGE",
            "FETCH_OBJECT",
            "SYNC_STATE",
            "REQUEST_CONSENT",
            "ROTATE_KEY",
            "CLOSE_SESSION"
          ]
        },
        "retry_after_ms": {
          "type": "integer",
          "minimum": 0
        },
        "details": {
          "type": "string"
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    }
  }
}
