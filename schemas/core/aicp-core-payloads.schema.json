{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aicp.dev/schemas/aicp-core-payloads.schema.json",
  "title": "AICP Core Payload Schemas",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "CONTRACT_PROPOSE": {
      "type": "object",
      "required": ["contract"],
      "properties": {
        "contract": {
          "type": "object",
          "additionalProperties": true
        },
        "contract_hash": {
          "type": "string",
          "minLength": 1
        },
        "note": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "CONTRACT_ACCEPT": {
      "type": "object",
      "required": ["accepted"],
      "properties": {
        "accepted": { "type": "boolean" },
        "replay": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "CONTEXT_AMEND": {
      "type": "object",
      "required": ["amendment"],
      "properties": {
        "amendment": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "ATTEST_ACTION": {
      "type": "object",
      "required": [
        "action_id",
        "action_type",
        "result_hash",
        "authority_ref",
        "scope_ref"
      ],
      "properties": {
        "action_id": { "type": "string", "minLength": 1 },
        "action_type": { "type": "string", "minLength": 1 },
        "result_hash": { "type": "string", "minLength": 1 },
        "authority_ref": { "type": "string", "minLength": 1 },
        "consent_ref": { "type": "string", "minLength": 1 },
        "scope_ref": { "type": "string", "minLength": 1 },
        "tool_name": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "RESOLVE_CONFLICT": {
      "type": "object",
      "required": ["conflict_id", "conflict_class", "resolution", "candidates"],
      "properties": {
        "conflict_id": { "type": "string", "minLength": 1 },
        "conflict_class": { "type": "string", "minLength": 1 },
        "resolution": {
          "type": "object",
          "additionalProperties": true
        },
        "candidates": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": false
    }
  }
}
