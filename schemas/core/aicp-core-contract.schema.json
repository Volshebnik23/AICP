{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aicp.dev/schemas/aicp-core-contract.schema.json",
  "title": "AICP Core Contract",
  "type": "object",
  "required": [
    "contract_id",
    "goal",
    "roles"
  ],
  "properties": {
    "contract_id": {
      "type": "string",
      "minLength": 1
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "roles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "policies": {
      "type": "object"
    },
    "extensions": {
      "type": "object"
    },
    "ext": {
      "type": "object"
    }
  },
  "additionalProperties": true
}