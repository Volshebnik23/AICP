{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aicp.dev/schemas/bindings/bind-mcp.schema.json",
  "title": "AICP MCP Binding Test Case",
  "type": "object",
  "required": ["case_id", "mcp_request", "mcp_response"],
  "properties": {
    "case_id": { "type": "string", "minLength": 1 },
    "notes": { "type": "string" },
    "mcp_request": {
      "type": "object",
      "required": ["jsonrpc", "id", "method", "params"],
      "properties": {
        "jsonrpc": { "const": "2.0" },
        "id": {
          "oneOf": [
            { "type": "string", "minLength": 1 },
            { "type": "integer" }
          ]
        },
        "method": { "const": "tools/call" },
        "params": {
          "type": "object",
          "required": ["name", "arguments"],
          "properties": {
            "name": {
              "type": "string",
              "enum": ["aicp.sendMessage", "aicp.getHead", "aicp.getObject"]
            },
            "arguments": {
              "type": "object",
              "additionalProperties": true
            }
          },
          "additionalProperties": false,
          "allOf": [
            {
              "if": {
                "properties": {
                  "name": { "const": "aicp.sendMessage" }
                }
              },
              "then": {
                "properties": {
                  "arguments": {
                    "type": "object",
                    "required": ["message"],
                    "properties": {
                      "message": { "$ref": "aicp:schemas/core/aicp-core-message.schema.json" }
                    },
                    "additionalProperties": true
                  }
                }
              }
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "mcp_response": {
      "type": "object",
      "required": ["jsonrpc", "id", "result"],
      "properties": {
        "jsonrpc": { "const": "2.0" },
        "id": {
          "oneOf": [
            { "type": "string", "minLength": 1 },
            { "type": "integer" }
          ]
        },
        "result": { "type": "object" },
        "error": { "type": "object" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
