{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aicp.dev/schemas/extensions/ext-provenance-payloads.schema.json",
  "title": "AICP EXT-PROVENANCE payloads",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "NonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "NodeType": {
      "type": "string",
      "enum": [
        "artifact_node",
        "transform_node",
        "decision_node"
      ]
    },
    "StringArray": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/NonEmptyString"
      }
    },
    "ProvenanceNode": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "node_id",
        "node_type"
      ],
      "properties": {
        "node_id": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "node_type": {
          "$ref": "#/$defs/NodeType"
        },
        "parent_node_ids": {
          "$ref": "#/$defs/StringArray"
        },
        "artifact_ref": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "content_hash": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "originator": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "operation_ref": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "input_refs": {
          "$ref": "#/$defs/StringArray"
        },
        "output_refs": {
          "$ref": "#/$defs/StringArray"
        },
        "policy_ref": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "approval_ref": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "constraint_ref": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "workflow_ref": {
          "$ref": "#/$defs/NonEmptyString"
        }
      }
    },
    "PROVENANCE_DECLARE": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "graph_id",
        "nodes"
      ],
      "properties": {
        "graph_id": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "nodes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/ProvenanceNode"
          }
        },
        "graph_ref": {
          "$ref": "#/$defs/NonEmptyString"
        }
      }
    },
    "PROVENANCE_APPEND": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "graph_id",
        "node"
      ],
      "properties": {
        "graph_id": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "node": {
          "$ref": "#/$defs/ProvenanceNode"
        }
      }
    }
  }
}
