{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aicp.dev/schemas/extensions/ext-workflow-sync-payloads.schema.json",
  "title": "AICP EXT-WORKFLOW-SYNC payloads",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "StringArray": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "WorkflowArtifactRef": {
      "type": "object",
      "required": ["object_type", "object", "object_hash"],
      "properties": {
        "object_type": { "type": "string", "const": "workflow" },
        "object": { "type": "object", "additionalProperties": true },
        "object_hash": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "WORKFLOW_DECLARE": {
      "type": "object",
      "required": ["workflow_id", "contract_head_version", "version", "workflow_artifact_ref"],
      "properties": {
        "workflow_id": { "type": "string", "minLength": 1 },
        "contract_head_version": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "workflow_artifact_ref": { "$ref": "#/$defs/WorkflowArtifactRef" },
        "workflow_hash": { "type": "string", "minLength": 1 },
        "step_index": { "type": "integer", "minimum": 0 },
        "policies_applied": { "$ref": "#/$defs/StringArray" },
        "note": { "type": "string" }
      },
      "additionalProperties": false
    },
    "WORKFLOW_UPDATE": {
      "type": "object",
      "required": ["workflow_id", "contract_head_version", "version", "base_workflow_hash", "workflow_artifact_ref"],
      "properties": {
        "workflow_id": { "type": "string", "minLength": 1 },
        "contract_head_version": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "base_workflow_hash": { "type": "string", "minLength": 1 },
        "workflow_artifact_ref": { "$ref": "#/$defs/WorkflowArtifactRef" },
        "workflow_hash": { "type": "string", "minLength": 1 },
        "note": { "type": "string" }
      },
      "additionalProperties": false
    },
    "WORKFLOW_STEP_ATTEST": {
      "type": "object",
      "required": ["workflow_id", "step_id", "contract_head_version", "status"],
      "properties": {
        "workflow_id": { "type": "string", "minLength": 1 },
        "step_id": { "type": "string", "minLength": 1 },
        "contract_head_version": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "enum": ["started", "completed", "failed", "skipped"] },
        "step_index": { "type": "integer", "minimum": 0 },
        "input_hash": { "type": "string", "minLength": 1 },
        "input_refs": { "$ref": "#/$defs/StringArray" },
        "output_hash": { "type": "string", "minLength": 1 },
        "output_refs": { "$ref": "#/$defs/StringArray" },
        "evidence_refs": { "$ref": "#/$defs/StringArray" },
        "started_at": { "type": "string", "format": "date-time" },
        "ended_at": { "type": "string", "format": "date-time" },
        "note": { "type": "string" }
      },
      "anyOf": [
        { "required": ["output_hash"] },
        { "required": ["output_refs"] }
      ],
      "additionalProperties": false
    }
  }
}
