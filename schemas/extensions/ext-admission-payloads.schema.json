{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aicp.dev/schemas/extensions/ext-admission-payloads.schema.json",
  "title": "AICP EXT-ADMISSION payloads",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "NonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "StringArray": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/NonEmptyString"}
    },
    "ReferenceStringArray": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "ReasonCodeString": {
      "type": "string"
    },
    "ADMISSION_REQUEST": {
      "type": "object",
      "additionalProperties": false,
      "required": ["request_id", "requested_roles", "requested_scopes", "risk_tier"],
      "properties": {
        "request_id": {"$ref": "#/$defs/NonEmptyString"},
        "requested_roles": {"$ref": "#/$defs/StringArray"},
        "requested_scopes": {"$ref": "#/$defs/StringArray"},
        "risk_tier": {"$ref": "#/$defs/NonEmptyString"},
        "attestation_refs": {"$ref": "#/$defs/ReferenceStringArray"},
        "stake_ref": {"$ref": "#/$defs/NonEmptyString"},
        "desired_quota_class": {"$ref": "#/$defs/NonEmptyString"},
        "priority_class": {"$ref": "#/$defs/NonEmptyString"}
      }
    },
    "ADMISSION_OFFER": {
      "type": "object",
      "additionalProperties": false,
      "required": ["request_id", "offer_id", "granted_roles", "granted_scopes", "quota_class", "lease_profile"],
      "properties": {
        "request_id": {"$ref": "#/$defs/NonEmptyString"},
        "offer_id": {"$ref": "#/$defs/NonEmptyString"},
        "granted_roles": {"$ref": "#/$defs/StringArray"},
        "granted_scopes": {"$ref": "#/$defs/StringArray"},
        "constraints": {
          "type": "array",
          "items": {"$ref": "#/$defs/NonEmptyString"}
        },
        "quota_class": {"$ref": "#/$defs/NonEmptyString"},
        "lease_profile": {"$ref": "#/$defs/NonEmptyString"},
        "required_approval": {"type": "boolean"}
      }
    },
    "ADMISSION_ACCEPT": {
      "type": "object",
      "additionalProperties": false,
      "required": ["request_id", "offer_id"],
      "properties": {
        "request_id": {"$ref": "#/$defs/NonEmptyString"},
        "offer_id": {"$ref": "#/$defs/NonEmptyString"},
        "accepted_at": {"type": "string", "format": "date-time"}
      }
    },
    "ADMISSION_REJECT": {
      "type": "object",
      "additionalProperties": false,
      "required": ["request_id", "reason_code"],
      "properties": {
        "request_id": {"$ref": "#/$defs/NonEmptyString"},
        "reason_code": {"$ref": "#/$defs/ReasonCodeString"},
        "detail_ref": {"$ref": "#/$defs/NonEmptyString"}
      }
    },
    "ADMISSION_RENEW": {
      "type": "object",
      "additionalProperties": false,
      "required": ["request_id", "prior_request_id", "reason_code"],
      "properties": {
        "request_id": {"$ref": "#/$defs/NonEmptyString"},
        "prior_request_id": {"$ref": "#/$defs/NonEmptyString"},
        "reason_code": {"$ref": "#/$defs/ReasonCodeString"},
        "attestation_refs": {"$ref": "#/$defs/ReferenceStringArray"}
      }
    },
    "ADMISSION_REVOKE": {
      "type": "object",
      "additionalProperties": false,
      "required": ["request_id", "reason_code"],
      "properties": {
        "request_id": {"$ref": "#/$defs/NonEmptyString"},
        "reason_code": {"$ref": "#/$defs/ReasonCodeString"},
        "revoked_at": {"type": "string", "format": "date-time"}
      }
    }
  }
}
