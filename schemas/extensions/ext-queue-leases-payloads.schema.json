{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aicp.dev/schemas/extensions/ext-queue-leases-payloads.schema.json",
  "title": "AICP EXT-QUEUE-LEASES payloads",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "NonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "StringArray": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/NonEmptyString"}
    },
    "QUEUE_ENQUEUE": {
      "type": "object",
      "additionalProperties": false,
      "required": ["queue_id", "item_id"],
      "properties": {
        "queue_id": {"$ref": "#/$defs/NonEmptyString"},
        "item_id": {"$ref": "#/$defs/NonEmptyString"},
        "priority_class": {"$ref": "#/$defs/NonEmptyString"},
        "desired_lease_profile": {"$ref": "#/$defs/NonEmptyString"}
      }
    },
    "QUEUE_LEASE_GRANT": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lease_id", "queue_id", "ttl_seconds", "max_msgs", "max_tool_calls"],
      "properties": {
        "lease_id": {"$ref": "#/$defs/NonEmptyString"},
        "queue_id": {"$ref": "#/$defs/NonEmptyString"},
        "ttl_seconds": {"type": "integer", "minimum": 1},
        "max_msgs": {"type": "integer", "minimum": 1},
        "max_tool_calls": {"type": "integer", "minimum": 0},
        "priority_class": {"$ref": "#/$defs/NonEmptyString"},
        "cursor": {"$ref": "#/$defs/NonEmptyString"},
        "allowed_message_types": {"$ref": "#/$defs/StringArray"}
      }
    },
    "QUEUE_ACK": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lease_id", "item_id"],
      "properties": {
        "lease_id": {"$ref": "#/$defs/NonEmptyString"},
        "item_id": {"$ref": "#/$defs/NonEmptyString"}
      }
    },
    "QUEUE_NACK": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lease_id", "item_id", "reason_code", "retry_after_seconds"],
      "properties": {
        "lease_id": {"$ref": "#/$defs/NonEmptyString"},
        "item_id": {"$ref": "#/$defs/NonEmptyString"},
        "reason_code": {"$ref": "#/$defs/NonEmptyString"},
        "retry_after_seconds": {"type": "integer", "minimum": 1}
      }
    },
    "QUEUE_RELEASE": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lease_id"],
      "properties": {
        "lease_id": {"$ref": "#/$defs/NonEmptyString"},
        "reason_code": {"$ref": "#/$defs/NonEmptyString"}
      }
    },
    "OVERLOAD_SIGNAL": {
      "type": "object",
      "additionalProperties": false,
      "required": ["severity", "reason_code", "retry_after_seconds"],
      "properties": {
        "severity": {"$ref": "#/$defs/NonEmptyString"},
        "reason_code": {"$ref": "#/$defs/NonEmptyString"},
        "retry_after_seconds": {"type": "integer", "minimum": 1},
        "degradation_mode": {"$ref": "#/$defs/NonEmptyString"},
        "allowed_message_types": {"$ref": "#/$defs/StringArray"}
      }
    },
    "THROTTLE_UPDATE": {
      "type": "object",
      "additionalProperties": false,
      "required": ["max_msgs_per_minute"],
      "properties": {
        "max_msgs_per_minute": {"type": "integer", "minimum": 1},
        "max_tool_calls_per_minute": {"type": "integer", "minimum": 0},
        "applies_to_message_types": {"$ref": "#/$defs/StringArray"}
      }
    }
  }
}
