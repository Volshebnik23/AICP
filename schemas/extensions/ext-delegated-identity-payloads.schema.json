{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aicp.dev/schemas/extensions/ext-delegated-identity-payloads.schema.json",
  "title": "AICP EXT-DELEGATED-IDENTITY payloads",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "SUBJECT_BINDING_OBJECT": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "binding_id",
        "agent_id",
        "account_id",
        "issuer",
        "scopes",
        "issued_at",
        "expires_at"
      ],
      "properties": {
        "binding_id": {"type": "string", "minLength": 1},
        "agent_id": {"type": "string", "minLength": 1},
        "account_id": {"type": "string", "minLength": 1},
        "issuer": {"type": "string", "minLength": 1},
        "scopes": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "issued_at": {"type": "string", "format": "date-time"},
        "expires_at": {"type": "string", "format": "date-time"}
      }
    },
    "SUBJECT_BINDING_REF": {
      "type": "object",
      "additionalProperties": false,
      "required": ["object_type", "object", "object_hash"],
      "properties": {
        "object_type": {"const": "subject_binding"},
        "object": {"$ref": "#/$defs/SUBJECT_BINDING_OBJECT"},
        "object_hash": {"type": "string", "minLength": 1}
      }
    },
    "SUBJECT_BINDING_ISSUE": {
      "type": "object",
      "additionalProperties": false,
      "required": ["binding_hash"],
      "properties": {
        "binding_hash": {"type": "string", "minLength": 1},
        "binding_ref": {"$ref": "#/$defs/SUBJECT_BINDING_REF"},
        "supersedes_binding_hash": {"type": "string", "minLength": 1},
        "note": {"type": "string"}
      }
    },
    "SUBJECT_BINDING_REVOKE": {
      "type": "object",
      "additionalProperties": false,
      "required": ["binding_hash", "effective_at"],
      "properties": {
        "binding_hash": {"type": "string", "minLength": 1},
        "effective_at": {"type": "string", "format": "date-time"},
        "reason_code": {"type": "string", "minLength": 1},
        "note": {"type": "string"}
      }
    }
  }
}
