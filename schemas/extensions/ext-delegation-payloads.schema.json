{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aicp.dev/schemas/extensions/ext-delegation-payloads.schema.json",
  "title": "AICP EXT-DELEGATION payloads",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "StringArray": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "DELEGATION_GRANT": {
      "type": "object",
      "required": [
        "delegation_id",
        "delegator",
        "delegatee",
        "authority_subset",
        "scope",
        "purpose",
        "expiry"
      ],
      "properties": {
        "delegation_id": {"type": "string", "minLength": 1},
        "delegator": {"type": "string", "minLength": 1},
        "delegatee": {"type": "string", "minLength": 1},
        "authority_subset": {"type": "object", "additionalProperties": true},
        "scope": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "purpose": {"type": "string", "minLength": 1},
        "expiry": {"type": "string", "format": "date-time"},
        "parent_delegation_id": {"type": "string", "minLength": 1},
        "acceptance_criteria": {"type": "string", "minLength": 1},
        "max_depth": {"type": "integer", "minimum": 0},
        "required_attestations": {"$ref": "#/$defs/StringArray"},
        "note": {"type": "string"}
      },
      "additionalProperties": false
    },
    "DELEGATION_ACCEPT": {
      "type": "object",
      "required": ["delegation_id"],
      "properties": {
        "delegation_id": {"type": "string", "minLength": 1},
        "accepted_at": {"type": "string", "format": "date-time"},
        "note": {"type": "string"}
      },
      "additionalProperties": false
    },
    "DELEGATION_REVOKE": {
      "type": "object",
      "required": ["delegation_id", "effective_at"],
      "properties": {
        "delegation_id": {"type": "string", "minLength": 1},
        "effective_at": {"type": "string", "format": "date-time"},
        "reason_code": {"type": "string", "minLength": 1},
        "note": {"type": "string"}
      },
      "additionalProperties": false
    },
    "DELEGATION_RESULT_ATTEST": {
      "type": "object",
      "required": ["delegation_id", "result_hash", "contract_head_version"],
      "properties": {
        "delegation_id": {"type": "string", "minLength": 1},
        "result_hash": {"type": "string", "minLength": 1},
        "contract_head_version": {"type": "string", "minLength": 1},
        "evidence_refs": {"$ref": "#/$defs/StringArray"},
        "note": {"type": "string"}
      },
      "additionalProperties": false
    }
  }
}
